#!/usr/bin/env bash
# Pre-commit hook: format check staged C# files
set -e

STAGED_CS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$' || true)

if [ -z "$STAGED_CS" ]; then
    exit 0
fi

echo "Checking C# formatting..."

if command -v dotnet >/dev/null 2>&1; then
    dotnet format DungeonGame.sln --verify-no-changes 2>&1 || {
        echo "Format check failed. Run 'dotnet format' to fix."
        exit 1
    }
else
    echo "Warning: dotnet not installed. Skipping format check."
fi

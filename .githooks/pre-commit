#!/usr/bin/env bash
# Pre-commit hook: format check staged C# files
#
# Scopes the check to *staged* files only, not the whole solution. This
# avoids flagging auto-generated files (e.g. gdUnit4's
# GdUnit4TestRunnerScene.cs, which ships with a BOM + CRLF on every
# build) as a blocker for unrelated commits.
set -e

STAGED_CS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$' || true)

if [ -z "$STAGED_CS" ]; then
    exit 0
fi

echo "Checking C# formatting on staged files..."

if command -v dotnet >/dev/null 2>&1; then
    dotnet format DungeonGame.sln --verify-no-changes --include $STAGED_CS 2>&1 || {
        echo "Format check failed. Run 'dotnet format --include <files>' to fix."
        exit 1
    }
else
    echo "Warning: dotnet not installed. Skipping format check."
fi

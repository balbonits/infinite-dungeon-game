<?xml version="1.0" encoding="utf-8" ?>
<!--
  coverlet.runsettings — code coverage configuration for `dotnet test`.

  IncludeTestAssembly=true is REQUIRED here because both test projects compile
  production source files in directly via <Compile Include="../../scripts/...">
  rather than referencing a separate DungeonGame.Logic.csproj. The "test
  assembly" therefore IS the production code under test — coverlet's default
  behavior of skipping the test assembly produces empty coverage reports.

  ExcludeByFile drops anything under tests/ from the coverage stat so the
  number reflects production-source coverage, not test-source coverage.
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <IncludeTestAssembly>true</IncludeTestAssembly>
          <ExcludeByFile>**/tests/**</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
